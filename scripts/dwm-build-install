#!/bin/sh

# Build and install dwm, replacing the currently installed version.
# Usage: dwm-build-install
#   or:  sudo dwm-build-install

set -e

SRCDIR="$(cd "$(dirname "$0")/.." && pwd)"

echo "==> Building dwm from $SRCDIR ..."
cd "$SRCDIR"
make clean
make

echo "==> Installing dwm (requires root) ..."
if [ "$(id -u)" -ne 0 ]; then
    sudo make install
else
    make install
fi

echo "==> Done. Restart dwm (Mod+Shift+Q) to use the new build."
